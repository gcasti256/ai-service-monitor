# Server
PORT=3100
HOST=0.0.0.0

# Database (SQLite is default — set DATABASE_URL for PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_monitor

# Data retention (days)
RETENTION_DAYS=30

# Alert webhooks (comma-separated URLs)
# ALERT_WEBHOOK_URLS=https://hooks.slack.com/services/xxx

# Dashboard
VITE_API_URL=http://localhost:3100

# Authentication (optional)
# API_KEY=your-secret-api-key

# CORS (restrict in production)
# CORS_ORIGIN=https://monitor.yourcompany.com
